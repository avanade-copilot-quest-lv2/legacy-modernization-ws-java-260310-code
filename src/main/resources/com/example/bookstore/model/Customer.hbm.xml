<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.example.bookstore.model">
    <class name="Customer" table="customer">
        <id name="id" column="id">
            <generator class="native"/>
        </id>

        <property name="email" column="email" type="string" length="255"/>
        <property name="pwdHash" column="pwd_hash" type="string" length="255"/>
        <property name="salt" column="salt" type="string" length="64"/>
        <property name="firstName" column="first_name" type="string" length="100"/>
        <property name="lastName" column="last_name" type="string" length="100"/>
        <property name="phone" column="phone" type="string" length="20"/>
        <property name="dob" column="dob" type="string" length="8"/>
        <property name="status" column="status" type="string" length="20"/>
        <property name="crtDt" column="crt_dt" type="string" length="14"/>
        <property name="updDt" column="upd_dt" type="string" length="14"/>
        <property name="delFlg" column="del_flg" type="string" length="1"/>
        <property name="reserve1" column="reserve1" type="string" length="200"/>
        <property name="reserve2" column="reserve2" type="string" length="200"/>
        <property name="reserve3" column="reserve3" type="string" length="200"/>
    </class>
</hibernate-mapping>
