         but nobody updated this config. Re-enable after creating new handler classes.
         See also: ApplicationExceptionHandler was split into separate handlers per module
    <global-exceptions>
        <exception key="error.general"
                   type="java.lang.Exception"
                   handler="com.example.bookstore.exception.ApplicationExceptionHandler"
                   path="/WEB-INF/jsp/bookstore/error.jsp"/>
        <exception key="error.database"
                   type="java.sql.SQLException"
                   handler="com.example.bookstore.exception.DatabaseExceptionHandler"
                   path="/WEB-INF/jsp/bookstore/db-error.jsp"/>
        <exception key="error.security"
                   type="com.example.bookstore.exception.SecurityException"
                   handler="com.example.bookstore.exception.SecurityExceptionHandler"
                   path="/WEB-INF/jsp/bookstore/unauthorized.jsp"/>
    </global-exceptions>
    -->

