<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.example.bookstore.model">
    <class name="Address" table="address">
        <id name="id" column="id">
            <generator class="native"/>
        </id>

        <property name="customerId" column="customer_id" type="string" length="20"/>
        <property name="addressType" column="address_type" type="string" length="20"/>
        <property name="fullName" column="full_name" type="string" length="200"/>
            <property name="addrLine1" column="addr_line1" type="string" length="255"/>
            <property name="addr_line2" column="addr_line2" type="string" length="255"/>
        <property name="city" column="city" type="string" length="100"/>
        <property name="state" column="state" type="string" length="100"/>
        <property name="zipCode" column="zip_code" type="string" length="20"/>
        <property name="country" column="country" type="string" length="100"/>
        <property name="phone" column="phone" type="string" length="20"/>
        <property name="isDefault" column="is_default" type="string" length="1"/>
        <property name="crtDt" column="crt_dt" type="string" length="14"/>
        <property name="updDt" column="upd_dt" type="string" length="14"/>
    </class>
</hibernate-mapping>
