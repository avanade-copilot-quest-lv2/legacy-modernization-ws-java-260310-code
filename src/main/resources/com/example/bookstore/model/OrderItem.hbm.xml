<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.example.bookstore.model">
    <class name="OrderItem" table="order_items">
        <id name="id" column="id">
            <generator class="native"/>
        </id>

        <property name="orderId" column="order_id" type="string" length="20"/>
        <property name="bookId" column="book_id" type="string" length="20"/>
        <property name="qty" column="qty" type="string" length="10"/>
        <property name="unitPrice" column="unit_price" type="double"/>
        <property name="discount" column="discount" type="double"/>
        <property name="subtotal" column="subtotal" type="double"/>
        <property name="crtDt" column="crt_dt" type="string" length="14"/>
    </class>
</hibernate-mapping>
