    <!-- OLD: cvs-tag target from when we used CVS for version control (2003~2005)
         We switched to SVN in 2006 but this target documents the old process.
         suzuki: I think we can delete this now? (2007/02)
         tanaka: keep it, the tag naming convention is documented here (2007/02)
    <target name="cvs-tag">
        <echo message="Tagging CVS with release tag..."/>
        <tstamp>
            <format property="tag.date" pattern="yyyyMMdd"/>
        </tstamp>
        <property name="cvs.tag" value="RELEASE_${tag.date}"/>
        <echo message="Tag: ${cvs.tag}"/>
        <cvs cvsRoot="${cvs.root}"
             command="tag ${cvs.tag}"
             failonerror="false"/>
        <echo message="CVS tag ${cvs.tag} applied."/>
        <echo message="To check out this tag:"/>
        <echo message="  cvs -d ${cvs.root} co -r ${cvs.tag} bookstore"/>
