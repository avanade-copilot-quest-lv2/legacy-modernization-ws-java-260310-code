{
    "name": "Java Legacy Development Environment",
    "image": "mcr.microsoft.com/devcontainers/java:8-bullseye",
    "customizations": {
        "vscode": {
            "extensions": [
                "redhat.java",
                "redhat.vscode-xml",
                "eamodio.gitlens",
                "ms-ceintl.vscode-language-pack-ja",
                "vscode-icons-team.vscode-icons"
            ],
            "settings": {
                "java.compile.nullAnalysis.mode": "disabled",
                "java.saveActions.organizeImports": false,
                "java.autobuild.enabled": false,
                "java.project.sourcePaths": ["src/main/java"],
                "java.project.outputPath": "build/classes",
                "java.project.referencedLibraries": [
                    "lib/**/*.jar",
                    "src/main/webapp/WEB-INF/lib/**/*.jar"
                ],
                "editor.tabSize": 4,
                "editor.insertSpaces": true,
                "files.encoding": "utf8",
                "files.eol": "\n",
                "files.associations": {
                    "*.jsp": "jsp",
                    "*.xml": "xml",
                    "*.properties": "properties"
                },
                "terminal.integrated.defaultProfile.linux": "bash",
                "workbench.colorTheme": "GitHub Dark Default"
            }
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/java:1": {
            "version": "8",
            "installAnt": true
        }
    },
    "postCreateCommand": "echo '=== Java Development Environment Ready ===' && java -version && ant -version",
    "containerEnv": {
        "TZ": "Asia/Tokyo"
    }
}
