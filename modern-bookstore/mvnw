#!/bin/sh
# Maven Wrapper script
# This script downloads and runs Maven with the correct version

set -e

# Resolve the directory containing this script
basedir=$(cd "$(dirname "$0")" && pwd)

# Download Maven if not present
MAVEN_VERSION="3.9.6"
MAVEN_HOME="$basedir/.mvn/wrapper/maven"
MAVEN_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/${MAVEN_VERSION}/apache-maven-${MAVEN_VERSION}-bin.tar.gz"

if [ ! -d "$MAVEN_HOME" ]; then
    echo "Downloading Maven ${MAVEN_VERSION}..."
    mkdir -p "$basedir/.mvn/wrapper"
    curl -fsSL "$MAVEN_URL" | tar -xz -C "$basedir/.mvn/wrapper"
    mv "$basedir/.mvn/wrapper/apache-maven-${MAVEN_VERSION}" "$MAVEN_HOME"
fi

# Run Maven
exec "$MAVEN_HOME/bin/mvn" "$@"
